{
  "$defs": {
    "ParticleAgglomerationState": {
      "enum": [
        "primary_particles",
        "agglomerated",
        "aggregated",
        "mixed",
        "unknown"
      ],
      "title": "ParticleAgglomerationState",
      "type": "string"
    },
    "ParticleCompositionFamily": {
      "enum": [
        "polymer",
        "metal_oxide",
        "silica",
        "pigment",
        "hydroxyapatite",
        "carbon_based",
        "other"
      ],
      "title": "ParticleCompositionFamily",
      "type": "string"
    },
    "ParticleMaterialClass": {
      "enum": [
        "nanomaterial",
        "synthetic_polymer_microparticle",
        "non_plastic_micro_nano_particle"
      ],
      "title": "ParticleMaterialClass",
      "type": "string"
    },
    "ParticleMaterialContext": {
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "const": "particleMaterialContext.v1",
          "default": "particleMaterialContext.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "materialClass": {
          "$ref": "#/$defs/ParticleMaterialClass",
          "description": "High-level particle material class."
        },
        "nanoStatus": {
          "$ref": "#/$defs/ParticleNanoStatus",
          "description": "Whether the context is nano-specific."
        },
        "particleSizeDomain": {
          "$ref": "#/$defs/ParticleSizeDomain",
          "description": "Primary size-domain classification."
        },
        "compositionFamily": {
          "$ref": "#/$defs/ParticleCompositionFamily",
          "description": "Broad composition family."
        },
        "intentionallyManufacturedParticle": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Whether the material is an intentionally manufactured particle.",
          "title": "Intentionallymanufacturedparticle"
        },
        "insolubleOrBiopersistent": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Whether the particle is treated as insoluble or biopersistent.",
          "title": "Insolubleorbiopersistent"
        },
        "solubilityClass": {
          "anyOf": [
            {
              "$ref": "#/$defs/ParticleSolubilityClass"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Screening solubility class."
        },
        "agglomerationState": {
          "anyOf": [
            {
              "$ref": "#/$defs/ParticleAgglomerationState"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Agglomeration or aggregation state relevant to use."
        },
        "shapeFamily": {
          "anyOf": [
            {
              "$ref": "#/$defs/ParticleShapeFamily"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Particle shape family."
        },
        "surfaceTreated": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Whether the particle has a relevant surface treatment or coating.",
          "title": "Surfacetreated"
        },
        "surfaceTreatmentNotes": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Short notes on coatings or surface treatment when known.",
          "title": "Surfacetreatmentnotes"
        },
        "medianPrimaryParticleSizeNm": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Median primary particle size in nm when known.",
          "title": "Medianprimaryparticlesizenm"
        },
        "sizeRangeNmLow": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Lower particle size bound in nm.",
          "title": "Sizerangenmlow"
        },
        "sizeRangeNmHigh": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Upper particle size bound in nm.",
          "title": "Sizerangenmhigh"
        },
        "respirableFractionRelevance": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Whether inhalation respirable-fraction context is materially relevant.",
          "title": "Respirablefractionrelevance"
        },
        "dermalPenetrationConcern": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Whether dermal particle penetration or retention is a relevant concern.",
          "title": "Dermalpenetrationconcern"
        },
        "article16NotificationRelevant": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Whether EU cosmetics Article 16 nanomaterial notification context applies.",
          "title": "Article16Notificationrelevant"
        },
        "echaSpmRestrictionRelevant": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Whether EU synthetic polymer microparticle restriction/reporting context applies.",
          "title": "Echaspmrestrictionrelevant"
        },
        "notes": {
          "description": "Additional material-context notes.",
          "items": {
            "type": "string"
          },
          "title": "Notes",
          "type": "array"
        }
      },
      "required": [
        "materialClass",
        "nanoStatus",
        "particleSizeDomain",
        "compositionFamily"
      ],
      "title": "ParticleMaterialContext",
      "type": "object"
    },
    "ParticleNanoStatus": {
      "enum": [
        "nano_specific",
        "contains_nano_fraction",
        "non_nano",
        "unknown"
      ],
      "title": "ParticleNanoStatus",
      "type": "string"
    },
    "ParticleShapeFamily": {
      "enum": [
        "spherical",
        "fibrous",
        "platelet",
        "irregular",
        "rod_like",
        "unknown"
      ],
      "title": "ParticleShapeFamily",
      "type": "string"
    },
    "ParticleSizeDomain": {
      "enum": [
        "nano",
        "micro",
        "mixed_micro_nano",
        "unknown"
      ],
      "title": "ParticleSizeDomain",
      "type": "string"
    },
    "ParticleSolubilityClass": {
      "enum": [
        "insoluble",
        "poorly_soluble",
        "soluble",
        "dissolves_rapidly",
        "unknown"
      ],
      "title": "ParticleSolubilityClass",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "productUseEvidenceRecord.v1",
      "default": "productUseEvidenceRecord.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "chemical_id": {
      "description": "Stable chemical identifier shared with the request.",
      "title": "Chemical Id",
      "type": "string"
    },
    "preferred_name": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Preferred chemical name when the evidence source also carries identity data.",
      "title": "Preferred Name"
    },
    "casrn": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "CAS Registry Number when known.",
      "title": "Casrn"
    },
    "source_name": {
      "description": "Human-readable evidence-source label.",
      "title": "Source Name",
      "type": "string"
    },
    "source_kind": {
      "default": "other",
      "description": "What kind of upstream source produced the product-use evidence.",
      "enum": [
        "comptox",
        "consexpo",
        "sccs",
        "cosing",
        "nanomaterial_guidance",
        "microplastics_regulatory",
        "regulatory_dossier",
        "literature_pack",
        "user_upload",
        "other"
      ],
      "title": "Source Kind",
      "type": "string"
    },
    "review_status": {
      "default": "provisional",
      "description": "Whether the evidence has been reviewed for downstream use.",
      "enum": [
        "reviewed",
        "provisional",
        "unreviewed"
      ],
      "title": "Review Status",
      "type": "string"
    },
    "source_record_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Optional upstream record identifier such as a dossier or registry ID.",
      "title": "Source Record Id"
    },
    "source_locator": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Optional URL or logical locator for the upstream record.",
      "title": "Source Locator"
    },
    "product_name": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Optional product label or family name carried by the evidence source.",
      "title": "Product Name"
    },
    "product_subtype": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Optional narrower product-use subtype carried by the evidence source.",
      "title": "Product Subtype"
    },
    "product_use_categories": {
      "description": "Candidate product-use categories supported by the evidence source.",
      "items": {
        "type": "string"
      },
      "title": "Product Use Categories",
      "type": "array"
    },
    "physical_forms": {
      "description": "Physical forms supported by the evidence source.",
      "items": {
        "type": "string"
      },
      "title": "Physical Forms",
      "type": "array"
    },
    "application_methods": {
      "description": "Application methods supported by the evidence source.",
      "items": {
        "type": "string"
      },
      "title": "Application Methods",
      "type": "array"
    },
    "retention_types": {
      "description": "Retention or contact semantics supported by the evidence source.",
      "items": {
        "type": "string"
      },
      "title": "Retention Types",
      "type": "array"
    },
    "region_scopes": {
      "description": "Regions where the product-use evidence is considered applicable.",
      "items": {
        "type": "string"
      },
      "title": "Region Scopes",
      "type": "array"
    },
    "jurisdictions": {
      "description": "Jurisdictions or regulatory programs that back the evidence source.",
      "items": {
        "type": "string"
      },
      "title": "Jurisdictions",
      "type": "array"
    },
    "physchem_summary": {
      "additionalProperties": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "number"
          },
          {
            "type": "integer"
          },
          {
            "type": "boolean"
          },
          {
            "type": "null"
          }
        ]
      },
      "description": "Optional physicochemical context preserved for downstream review.",
      "title": "Physchem Summary",
      "type": "object"
    },
    "particleMaterialContext": {
      "anyOf": [
        {
          "$ref": "#/$defs/ParticleMaterialContext"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Optional structured particle-aware material context."
    },
    "productUseProfileOverrides": {
      "additionalProperties": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "number"
          },
          {
            "type": "integer"
          },
          {
            "type": "boolean"
          },
          {
            "type": "null"
          }
        ]
      },
      "description": "Reviewed product-use profile fields suggested by the evidence source.",
      "title": "Productuseprofileoverrides",
      "type": "object"
    },
    "populationProfileOverrides": {
      "additionalProperties": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "number"
          },
          {
            "type": "integer"
          },
          {
            "type": "boolean"
          },
          {
            "type": "null"
          }
        ]
      },
      "description": "Reviewed population-profile fields suggested by the evidence source.",
      "title": "Populationprofileoverrides",
      "type": "object"
    },
    "evidence_sources": {
      "description": "Stable upstream evidence references backing the record.",
      "items": {
        "type": "string"
      },
      "title": "Evidence Sources",
      "type": "array"
    },
    "notes": {
      "description": "Additional applicability or review notes preserved verbatim.",
      "items": {
        "type": "string"
      },
      "title": "Notes",
      "type": "array"
    }
  },
  "required": [
    "chemical_id",
    "source_name"
  ],
  "title": "ProductUseEvidenceRecord",
  "type": "object"
}
