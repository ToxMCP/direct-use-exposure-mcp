    "exportPbpkExternalImportBundleRequest.v1": "schemas/exportPbpkExternalImportBundleRequest.v1.json",
    "exportToxClawEvidenceBundleRequest.v1": "schemas/exportToxClawEvidenceBundleRequest.v1.json",
    "exportToxClawRefinementBundleRequest.v1": "schemas/exportToxClawRefinementBundleRequest.v1.json",
    "compareExposureScenariosInput.v1": "schemas/compareExposureScenariosInput.v1.json",
    "compToxChemicalRecord.v1": "schemas/compToxChemicalRecord.v1.json",
    "toxclawEvidenceEnvelope.v1": "schemas/toxclawEvidenceEnvelope.v1.json",
    "toxclawEvidenceRecord.v1": "schemas/toxclawEvidenceRecord.v1.json",
