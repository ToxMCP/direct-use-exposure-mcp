    "toxclaw_pbpk_module_params": "schemas/examples/toxclaw_pbpk_module_params.json",
    "pbpk_external_import_package": "schemas/examples/pbpk_external_import_package.json",
    "comparison_record": "schemas/examples/comparison_record.json",
    "comp_tox_record": "schemas/examples/comp_tox_record.json",
