    "toxclawPbpkModuleParams.v1": "schemas/toxclawPbpkModuleParams.v1.json",
    "toolResultMeta.v1": "schemas/toolResultMeta.v1.json",
    "releaseMetadataReport.v1": "schemas/releaseMetadataReport.v1.json",
