{
  "$defs": {
    "ApplicabilityStatus": {
      "enum": [
        "user_asserted",
        "in_domain",
        "screening_extrapolation",
        "derived"
      ],
      "title": "ApplicabilityStatus",
      "type": "string"
    },
    "AssumptionGovernance": {
      "additionalProperties": false,
      "properties": {
        "evidence_grade": {
          "anyOf": [
            {
              "$ref": "#/$defs/EvidenceGrade"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Ordinal evidence grade for defaults or curated source families, where grade_4 is strongest and grade_1 is heuristic."
        },
        "evidence_basis": {
          "$ref": "#/$defs/EvidenceBasis",
          "description": "Whether the value was explicit input, curated default, heuristic, or derived."
        },
        "default_visibility": {
          "$ref": "#/$defs/DefaultVisibility",
          "description": "Whether the assumption can remain silently traceable, must warn, or would block."
        },
        "applicability_status": {
          "$ref": "#/$defs/ApplicabilityStatus",
          "description": "Whether the parameter is in-domain, user-asserted, or a screening extrapolation."
        },
        "uncertainty_types": {
          "description": "Primary uncertainty families attached to the parameter.",
          "items": {
            "$ref": "#/$defs/UncertaintyType"
          },
          "title": "Uncertainty Types",
          "type": "array"
        },
        "applicability_domain": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              },
              {
                "type": "integer"
              },
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ]
          },
          "description": "Structured scenario context that describes where this value is intended to apply.",
          "title": "Applicability Domain",
          "type": "object"
        }
      },
      "required": [
        "evidence_basis",
        "default_visibility",
        "applicability_status"
      ],
      "title": "AssumptionGovernance",
      "type": "object"
    },
    "AssumptionSourceReference": {
      "additionalProperties": false,
      "properties": {
        "source_id": {
          "description": "Stable identifier for the source.",
          "title": "Source Id",
          "type": "string"
        },
        "title": {
          "description": "Human-readable source title.",
          "title": "Title",
          "type": "string"
        },
        "locator": {
          "description": "URL, file path, or logical locator.",
          "title": "Locator",
          "type": "string"
        },
        "version": {
          "description": "Version or effective date for the source.",
          "title": "Version",
          "type": "string"
        },
        "hash_sha256": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Content hash when available.",
          "title": "Hash Sha256"
        }
      },
      "required": [
        "source_id",
        "title",
        "locator",
        "version"
      ],
      "title": "AssumptionSourceReference",
      "type": "object"
    },
    "DefaultVisibility": {
      "enum": [
        "silent_traceable",
        "warn",
        "block"
      ],
      "title": "DefaultVisibility",
      "type": "string"
    },
    "EvidenceBasis": {
      "enum": [
        "explicit_input",
        "curated_default",
        "heuristic_default",
        "derived"
      ],
      "title": "EvidenceBasis",
      "type": "string"
    },
    "EvidenceGrade": {
      "enum": [
        "grade_4",
        "grade_3",
        "grade_2",
        "grade_1"
      ],
      "title": "EvidenceGrade",
      "type": "string"
    },
    "SourceKind": {
      "enum": [
        "user_input",
        "default_registry",
        "derived",
        "system"
      ],
      "title": "SourceKind",
      "type": "string"
    },
    "UncertaintyType": {
      "enum": [
        "variability",
        "parameter_uncertainty",
        "model_uncertainty",
        "scenario_uncertainty"
      ],
      "title": "UncertaintyType",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "exposureAssumptionRecord.v1",
      "default": "exposureAssumptionRecord.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "name": {
      "description": "Stable parameter name used by the engine.",
      "title": "Name",
      "type": "string"
    },
    "value": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "number"
        },
        {
          "type": "integer"
        },
        {
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ],
      "description": "The resolved assumption value.",
      "title": "Value"
    },
    "unit": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Resolved unit, if applicable.",
      "title": "Unit"
    },
    "source_kind": {
      "$ref": "#/$defs/SourceKind",
      "description": "Whether the value was user supplied, defaulted, or derived."
    },
    "source": {
      "$ref": "#/$defs/AssumptionSourceReference",
      "description": "Source reference for the assumption."
    },
    "confidence": {
      "description": "Human-readable confidence label.",
      "title": "Confidence",
      "type": "string"
    },
    "default_applied": {
      "description": "Whether a default value was applied.",
      "title": "Default Applied",
      "type": "boolean"
    },
    "rationale": {
      "description": "Why this assumption was used.",
      "title": "Rationale",
      "type": "string"
    },
    "governance": {
      "$ref": "#/$defs/AssumptionGovernance",
      "description": "Scientific-governance metadata for defaulting, applicability, and uncertainty."
    }
  },
  "required": [
    "name",
    "value",
    "source_kind",
    "source",
    "confidence",
    "default_applied",
    "rationale",
    "governance"
  ],
  "title": "ExposureAssumptionRecord",
  "type": "object"
}
