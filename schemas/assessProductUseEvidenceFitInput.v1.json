{
  "$defs": {
    "ExposureScenarioRequest": {
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "const": "exposureScenarioRequest.v1",
          "default": "exposureScenarioRequest.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "chemical_id": {
          "description": "Stable chemical identifier.",
          "title": "Chemical Id",
          "type": "string"
        },
        "chemical_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional chemical name.",
          "title": "Chemical Name"
        },
        "route": {
          "$ref": "#/$defs/Route",
          "description": "Requested exposure route."
        },
        "scenario_class": {
          "$ref": "#/$defs/ScenarioClass",
          "default": "screening",
          "description": "Requested scenario class."
        },
        "product_use_profile": {
          "$ref": "#/$defs/ProductUseProfile",
          "description": "Product and use-context profile."
        },
        "population_profile": {
          "$ref": "#/$defs/PopulationProfile",
          "description": "Population profile for the exposed cohort."
        },
        "assumption_overrides": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              },
              {
                "type": "integer"
              },
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ]
          },
          "description": "Additional explicit overrides for auditability.",
          "title": "Assumption Overrides",
          "type": "object"
        }
      },
      "required": [
        "chemical_id",
        "route",
        "product_use_profile",
        "population_profile"
      ],
      "title": "ExposureScenarioRequest",
      "type": "object"
    },
    "PopulationProfile": {
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "const": "populationProfile.v1",
          "default": "populationProfile.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "population_group": {
          "description": "Population group, for example adult or child.",
          "title": "Population Group",
          "type": "string"
        },
        "body_weight_kg": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Body weight in kilograms.",
          "title": "Body Weight Kg"
        },
        "inhalation_rate_m3_per_hour": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Inhalation rate for inhalation screening.",
          "title": "Inhalation Rate M3 Per Hour"
        },
        "exposed_surface_area_cm2": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Exposed surface area for dermal scenarios.",
          "title": "Exposed Surface Area Cm2"
        },
        "demographic_tags": {
          "description": "Demographic descriptors for auditability.",
          "items": {
            "type": "string"
          },
          "title": "Demographic Tags",
          "type": "array"
        },
        "region": {
          "default": "global",
          "description": "Regional context for defaults or interpretation.",
          "title": "Region",
          "type": "string"
        }
      },
      "required": [
        "population_group"
      ],
      "title": "PopulationProfile",
      "type": "object"
    },
    "ProductAmountUnit": {
      "enum": [
        "g",
        "mL"
      ],
      "title": "ProductAmountUnit",
      "type": "string"
    },
    "ProductUseEvidenceRecord": {
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "const": "productUseEvidenceRecord.v1",
          "default": "productUseEvidenceRecord.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "chemical_id": {
          "description": "Stable chemical identifier shared with the request.",
          "title": "Chemical Id",
          "type": "string"
        },
        "preferred_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Preferred chemical name when the evidence source also carries identity data.",
          "title": "Preferred Name"
        },
        "casrn": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "CAS Registry Number when known.",
          "title": "Casrn"
        },
        "source_name": {
          "description": "Human-readable evidence-source label.",
          "title": "Source Name",
          "type": "string"
        },
        "source_kind": {
          "default": "other",
          "description": "What kind of upstream source produced the product-use evidence.",
          "enum": [
            "comptox",
            "consexpo",
            "regulatory_dossier",
            "literature_pack",
            "user_upload",
            "other"
          ],
          "title": "Source Kind",
          "type": "string"
        },
        "review_status": {
          "default": "provisional",
          "description": "Whether the evidence has been reviewed for downstream use.",
          "enum": [
            "reviewed",
            "provisional",
            "unreviewed"
          ],
          "title": "Review Status",
          "type": "string"
        },
        "source_record_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional upstream record identifier such as a dossier or registry ID.",
          "title": "Source Record Id"
        },
        "source_locator": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional URL or logical locator for the upstream record.",
          "title": "Source Locator"
        },
        "product_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional product label or family name carried by the evidence source.",
          "title": "Product Name"
        },
        "product_subtype": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional narrower product-use subtype carried by the evidence source.",
          "title": "Product Subtype"
        },
        "product_use_categories": {
          "description": "Candidate product-use categories supported by the evidence source.",
          "items": {
            "type": "string"
          },
          "title": "Product Use Categories",
          "type": "array"
        },
        "physical_forms": {
          "description": "Physical forms supported by the evidence source.",
          "items": {
            "type": "string"
          },
          "title": "Physical Forms",
          "type": "array"
        },
        "application_methods": {
          "description": "Application methods supported by the evidence source.",
          "items": {
            "type": "string"
          },
          "title": "Application Methods",
          "type": "array"
        },
        "retention_types": {
          "description": "Retention or contact semantics supported by the evidence source.",
          "items": {
            "type": "string"
          },
          "title": "Retention Types",
          "type": "array"
        },
        "region_scopes": {
          "description": "Regions where the product-use evidence is considered applicable.",
          "items": {
            "type": "string"
          },
          "title": "Region Scopes",
          "type": "array"
        },
        "jurisdictions": {
          "description": "Jurisdictions or regulatory programs that back the evidence source.",
          "items": {
            "type": "string"
          },
          "title": "Jurisdictions",
          "type": "array"
        },
        "physchem_summary": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              },
              {
                "type": "integer"
              },
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ]
          },
          "description": "Optional physicochemical context preserved for downstream review.",
          "title": "Physchem Summary",
          "type": "object"
        },
        "evidence_sources": {
          "description": "Stable upstream evidence references backing the record.",
          "items": {
            "type": "string"
          },
          "title": "Evidence Sources",
          "type": "array"
        },
        "notes": {
          "description": "Additional applicability or review notes preserved verbatim.",
          "items": {
            "type": "string"
          },
          "title": "Notes",
          "type": "array"
        }
      },
      "required": [
        "chemical_id",
        "source_name"
      ],
      "title": "ProductUseEvidenceRecord",
      "type": "object"
    },
    "ProductUseProfile": {
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "const": "productUseProfile.v1",
          "default": "productUseProfile.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "product_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional human-readable product label.",
          "title": "Product Name"
        },
        "product_subtype": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional narrower product-use subtype such as indoor_surface_insecticide or surface_trigger_spray_disinfectant.",
          "title": "Product Subtype"
        },
        "product_category": {
          "description": "Product category or PUC-like category.",
          "title": "Product Category",
          "type": "string"
        },
        "physical_form": {
          "description": "Physical form such as cream, liquid, spray, or gel.",
          "title": "Physical Form",
          "type": "string"
        },
        "application_method": {
          "description": "How the product is applied, for example hand_application or trigger_spray.",
          "title": "Application Method",
          "type": "string"
        },
        "retention_type": {
          "default": "leave_on",
          "description": "Retention class such as leave_on or rinse_off.",
          "title": "Retention Type",
          "type": "string"
        },
        "concentration_fraction": {
          "description": "Fraction of the target chemical in the product, 0-1.",
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Concentration Fraction",
          "type": "number"
        },
        "use_amount_per_event": {
          "description": "Product amount used per event.",
          "exclusiveMinimum": 0.0,
          "title": "Use Amount Per Event",
          "type": "number"
        },
        "use_amount_unit": {
          "$ref": "#/$defs/ProductAmountUnit",
          "description": "Unit for the use amount per event."
        },
        "use_events_per_day": {
          "description": "Number of product-use events per day.",
          "exclusiveMinimum": 0.0,
          "title": "Use Events Per Day",
          "type": "number"
        },
        "density_g_per_ml": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Density when the product amount is in mL.",
          "title": "Density G Per Ml"
        },
        "transfer_efficiency": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "maximum": 1.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Route modifier for external transfer.",
          "title": "Transfer Efficiency"
        },
        "retention_factor": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "maximum": 1.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Retention modifier for dermal screening.",
          "title": "Retention Factor"
        },
        "ingestion_fraction": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "maximum": 1.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Fraction of chemical mass incidentally or directly ingested.",
          "title": "Ingestion Fraction"
        },
        "aerosolized_fraction": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "maximum": 1.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Fraction of chemical mass released to air.",
          "title": "Aerosolized Fraction"
        },
        "room_volume_m3": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Indoor room volume for inhalation screening.",
          "title": "Room Volume M3"
        },
        "air_exchange_rate_per_hour": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Air exchange rate for inhalation screening.",
          "title": "Air Exchange Rate Per Hour"
        },
        "exposure_duration_hours": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Duration of exposure per event.",
          "title": "Exposure Duration Hours"
        }
      },
      "required": [
        "product_category",
        "physical_form",
        "application_method",
        "concentration_fraction",
        "use_amount_per_event",
        "use_amount_unit",
        "use_events_per_day"
      ],
      "title": "ProductUseProfile",
      "type": "object"
    },
    "Route": {
      "enum": [
        "dermal",
        "oral",
        "inhalation"
      ],
      "title": "Route",
      "type": "string"
    },
    "ScenarioClass": {
      "enum": [
        "screening",
        "aggregate",
        "inhalation",
        "refined",
        "population_distribution"
      ],
      "title": "ScenarioClass",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "assessProductUseEvidenceFitInput.v1",
      "default": "assessProductUseEvidenceFitInput.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "request": {
      "$ref": "#/$defs/ExposureScenarioRequest",
      "description": "Scenario request to assess."
    },
    "evidence": {
      "$ref": "#/$defs/ProductUseEvidenceRecord",
      "description": "Generic product-use evidence supplied by CompTox or another source."
    }
  },
  "required": [
    "request",
    "evidence"
  ],
  "title": "AssessProductUseEvidenceFitInput",
  "type": "object"
}
