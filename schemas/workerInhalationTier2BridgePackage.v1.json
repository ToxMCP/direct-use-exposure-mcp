{
  "$defs": {
    "LimitationNote": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "description": "Stable machine-readable limitation code.",
          "title": "Code",
          "type": "string"
        },
        "severity": {
          "$ref": "#/$defs/Severity",
          "default": "warning",
          "description": "Limitation severity."
        },
        "message": {
          "description": "Human-readable limitation text.",
          "title": "Message",
          "type": "string"
        }
      },
      "required": [
        "code",
        "message"
      ],
      "title": "LimitationNote",
      "type": "object"
    },
    "ProvenanceBundle": {
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "const": "provenanceBundle.v1",
          "default": "provenanceBundle.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "algorithm_id": {
          "description": "Stable algorithm identifier.",
          "title": "Algorithm Id",
          "type": "string"
        },
        "plugin_id": {
          "description": "Plugin that generated the result.",
          "title": "Plugin Id",
          "type": "string"
        },
        "plugin_version": {
          "description": "Plugin version.",
          "title": "Plugin Version",
          "type": "string"
        },
        "defaults_version": {
          "description": "Defaults pack version.",
          "title": "Defaults Version",
          "type": "string"
        },
        "defaults_hash_sha256": {
          "description": "Hash for the defaults pack in use.",
          "title": "Defaults Hash Sha256",
          "type": "string"
        },
        "generated_at": {
          "description": "ISO-8601 UTC timestamp.",
          "title": "Generated At",
          "type": "string"
        },
        "notes": {
          "description": "Additional provenance notes.",
          "items": {
            "type": "string"
          },
          "title": "Notes",
          "type": "array"
        }
      },
      "required": [
        "algorithm_id",
        "plugin_id",
        "plugin_version",
        "defaults_version",
        "defaults_hash_sha256",
        "generated_at"
      ],
      "title": "ProvenanceBundle",
      "type": "object"
    },
    "QualityFlag": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "description": "Stable machine-readable quality flag code.",
          "title": "Code",
          "type": "string"
        },
        "severity": {
          "$ref": "#/$defs/Severity",
          "default": "info",
          "description": "Quality signal severity."
        },
        "message": {
          "description": "Human-readable quality message.",
          "title": "Message",
          "type": "string"
        }
      },
      "required": [
        "code",
        "message"
      ],
      "title": "QualityFlag",
      "type": "object"
    },
    "Route": {
      "enum": [
        "dermal",
        "oral",
        "inhalation"
      ],
      "title": "Route",
      "type": "string"
    },
    "Severity": {
      "enum": [
        "info",
        "warning",
        "error"
      ],
      "title": "Severity",
      "type": "string"
    },
    "WorkerInhalationTier2AdapterRequest": {
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "const": "workerInhalationTier2AdapterRequest.v1",
          "default": "workerInhalationTier2AdapterRequest.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "targetAdapter": {
          "default": "future_worker_exposure_adapter",
          "description": "Target adapter boundary for the future occupational model.",
          "title": "Targetadapter",
          "type": "string"
        },
        "targetModelFamily": {
          "$ref": "#/$defs/WorkerTier2ModelFamily",
          "description": "Future occupational model family requested by the caller."
        },
        "sourceModule": {
          "default": "exposure-scenario-mcp",
          "description": "Source MCP that created the bridge package.",
          "title": "Sourcemodule",
          "type": "string"
        },
        "contextOfUse": {
          "description": "Downstream orchestration context for the bridge payload.",
          "title": "Contextofuse",
          "type": "string"
        },
        "chemicalIdentity": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              },
              {
                "type": "integer"
              },
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ]
          },
          "description": "Chemical identity block for the future worker adapter.",
          "title": "Chemicalidentity",
          "type": "object"
        },
        "taskContext": {
          "$ref": "#/$defs/WorkerInhalationTier2TaskContext",
          "description": "Typed worker-task context for Tier 2 refinement."
        },
        "exposureInputs": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              },
              {
                "type": "integer"
              },
              {
                "type": "boolean"
              },
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "items": {},
                "type": "array"
              },
              {
                "type": "null"
              }
            ]
          },
          "description": "Normalized inhalation exposure inputs preserved for the future adapter.",
          "title": "Exposureinputs",
          "type": "object"
        },
        "supportingHandoffs": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              },
              {
                "type": "integer"
              },
              {
                "type": "boolean"
              },
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "items": {},
                "type": "array"
              },
              {
                "type": "null"
              }
            ]
          },
          "description": "Source request and routing context preserved alongside the adapter payload.",
          "title": "Supportinghandoffs",
          "type": "object"
        },
        "guidanceResource": {
          "default": "docs://worker-tier2-bridge-guide",
          "description": "Worker Tier 2 guide that explains how to use the bridge.",
          "title": "Guidanceresource",
          "type": "string"
        }
      },
      "required": [
        "targetModelFamily",
        "contextOfUse",
        "taskContext"
      ],
      "title": "WorkerInhalationTier2AdapterRequest",
      "type": "object"
    },
    "WorkerInhalationTier2AdapterToolCall": {
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "const": "workerInhalationTier2AdapterToolCall.v1",
          "default": "workerInhalationTier2AdapterToolCall.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "toolName": {
          "default": "worker_ingest_inhalation_tier2_task",
          "description": "Future tool name that could consume the adapter request payload.",
          "title": "Toolname",
          "type": "string"
        },
        "arguments": {
          "$ref": "#/$defs/WorkerInhalationTier2AdapterRequest",
          "description": "Arguments that should be passed to the future worker adapter."
        }
      },
      "required": [
        "arguments"
      ],
      "title": "WorkerInhalationTier2AdapterToolCall",
      "type": "object"
    },
    "WorkerInhalationTier2CompatibilityReport": {
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "const": "workerInhalationTier2CompatibilityReport.v1",
          "default": "workerInhalationTier2CompatibilityReport.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "sourceRequestSchema": {
          "description": "Schema version of the source inhalation request.",
          "title": "Sourcerequestschema",
          "type": "string"
        },
        "targetModelFamily": {
          "$ref": "#/$defs/WorkerTier2ModelFamily",
          "description": "Future worker-model family targeted by the bridge."
        },
        "route": {
          "$ref": "#/$defs/Route",
          "default": "inhalation",
          "description": "Route represented by the bridge."
        },
        "workerDetected": {
          "description": "Whether worker context was detected from the population profile.",
          "title": "Workerdetected",
          "type": "boolean"
        },
        "readyForAdapter": {
          "description": "Whether the bridge carries the minimum inputs for a future adapter handoff.",
          "title": "Readyforadapter",
          "type": "boolean"
        },
        "missingFields": {
          "description": "Adapter-facing fields still missing from the bridge package.",
          "items": {
            "type": "string"
          },
          "title": "Missingfields",
          "type": "array"
        },
        "issues": {
          "description": "Warnings or blockers attached to the bridge readiness decision.",
          "items": {
            "$ref": "#/$defs/LimitationNote"
          },
          "title": "Issues",
          "type": "array"
        },
        "recommendedNextSteps": {
          "description": "Short next-step guidance for the downstream orchestrator.",
          "items": {
            "type": "string"
          },
          "title": "Recommendednextsteps",
          "type": "array"
        }
      },
      "required": [
        "sourceRequestSchema",
        "targetModelFamily",
        "workerDetected",
        "readyForAdapter"
      ],
      "title": "WorkerInhalationTier2CompatibilityReport",
      "type": "object"
    },
    "WorkerInhalationTier2TaskContext": {
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "const": "workerInhalationTier2TaskContext.v1",
          "default": "workerInhalationTier2TaskContext.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "task_description": {
          "description": "Short description of the workplace task.",
          "title": "Task Description",
          "type": "string"
        },
        "workplace_setting": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Short workplace-setting label such as janitorial closet or production line.",
          "title": "Workplace Setting"
        },
        "task_duration_hours": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Task duration relevant to the future Tier 2 worker model.",
          "title": "Task Duration Hours"
        },
        "task_intensity": {
          "anyOf": [
            {
              "$ref": "#/$defs/WorkerTaskIntensity"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional task-intensity class used to apply a bounded inhalation-rate adjustment in worker execution."
        },
        "ventilation_context": {
          "$ref": "#/$defs/WorkerVentilationContext",
          "default": "unknown",
          "description": "Ventilation/control state declared for the worker task."
        },
        "local_controls": {
          "description": "Engineering or administrative controls explicitly present during the task.",
          "items": {
            "type": "string"
          },
          "title": "Local Controls",
          "type": "array"
        },
        "levFamily": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional explicit LEV or hood family such as slot_hood, canopy_hood, downdraft_booth, or capture_nozzle.",
          "title": "Levfamily"
        },
        "hoodFaceVelocityMPerS": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional measured or declared hood-face/capture velocity in m/s used for bounded worker capture refinements.",
          "title": "Hoodfacevelocitympers"
        },
        "respiratory_protection": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Respiratory protection state if explicitly known.",
          "title": "Respiratory Protection"
        },
        "emission_descriptor": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Short free-text description of the emitted mist, vapor, or aerosol context.",
          "title": "Emission Descriptor"
        },
        "notes": {
          "description": "Additional worker-task notes preserved for adapter review.",
          "items": {
            "type": "string"
          },
          "title": "Notes",
          "type": "array"
        }
      },
      "required": [
        "task_description"
      ],
      "title": "WorkerInhalationTier2TaskContext",
      "type": "object"
    },
    "WorkerTaskIntensity": {
      "enum": [
        "light",
        "moderate",
        "high"
      ],
      "title": "WorkerTaskIntensity",
      "type": "string"
    },
    "WorkerTier2ModelFamily": {
      "enum": [
        "art",
        "stoffenmanager"
      ],
      "title": "WorkerTier2ModelFamily",
      "type": "string"
    },
    "WorkerVentilationContext": {
      "enum": [
        "unknown",
        "general_ventilation",
        "enhanced_general_ventilation",
        "local_exhaust",
        "enclosed_process",
        "outdoor"
      ],
      "title": "WorkerVentilationContext",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "workerInhalationTier2BridgePackage.v1",
      "default": "workerInhalationTier2BridgePackage.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "routingDecision": {
      "additionalProperties": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "number"
          },
          {
            "type": "integer"
          },
          {
            "type": "boolean"
          },
          {
            "additionalProperties": true,
            "type": "object"
          },
          {
            "items": {},
            "type": "array"
          },
          {
            "type": "null"
          }
        ]
      },
      "description": "Worker routing decision preserved inside the bridge package.",
      "title": "Routingdecision",
      "type": "object"
    },
    "adapterRequest": {
      "$ref": "#/$defs/WorkerInhalationTier2AdapterRequest",
      "description": "Normalized future adapter payload."
    },
    "toolCall": {
      "$ref": "#/$defs/WorkerInhalationTier2AdapterToolCall",
      "description": "Future adapter tool-call envelope."
    },
    "compatibilityReport": {
      "$ref": "#/$defs/WorkerInhalationTier2CompatibilityReport",
      "description": "Readiness and missing-input report for the worker Tier 2 bridge."
    },
    "qualityFlags": {
      "description": "Bridge-level warnings and status flags.",
      "items": {
        "$ref": "#/$defs/QualityFlag"
      },
      "title": "Qualityflags",
      "type": "array"
    },
    "provenance": {
      "$ref": "#/$defs/ProvenanceBundle",
      "description": "Bridge-package provenance."
    }
  },
  "required": [
    "routingDecision",
    "adapterRequest",
    "toolCall",
    "compatibilityReport",
    "provenance"
  ],
  "title": "WorkerInhalationTier2BridgePackage",
  "type": "object"
}
