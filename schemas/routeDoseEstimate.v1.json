{
  "$defs": {
    "ChemicalIdentity": {
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "const": "chemicalIdentity.v1",
          "default": "chemicalIdentity.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "chemicalId": {
          "description": "Stable suite-level chemical identifier used across MCP boundaries.",
          "title": "Chemicalid",
          "type": "string"
        },
        "preferredName": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Preferred human-readable chemical name for cross-MCP handoffs.",
          "title": "Preferredname"
        },
        "casrn": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "CAS Registry Number when available for reconciliation or review.",
          "title": "Casrn"
        },
        "dtxsid": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "EPA CompTox DTXSID when available.",
          "title": "Dtxsid"
        },
        "smiles": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Canonical or representative SMILES string when available.",
          "title": "Smiles"
        },
        "inchiKey": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "InChIKey when available for downstream identity reconciliation.",
          "title": "Inchikey"
        },
        "externalIdentifiers": {
          "additionalProperties": {
            "type": "string"
          },
          "description": "Additional external identifiers preserved verbatim for auditability.",
          "title": "Externalidentifiers",
          "type": "object"
        },
        "notes": {
          "description": "Additional identity notes that should remain attached to handoffs.",
          "items": {
            "type": "string"
          },
          "title": "Notes",
          "type": "array"
        }
      },
      "required": [
        "chemicalId"
      ],
      "title": "ChemicalIdentity",
      "type": "object"
    },
    "DoseUnit": {
      "enum": [
        "mg/day",
        "mg/event",
        "mg/kg-day",
        "mg/m3"
      ],
      "title": "DoseUnit",
      "type": "string"
    },
    "FitForPurpose": {
      "additionalProperties": false,
      "properties": {
        "label": {
          "description": "High-level fit-for-purpose label.",
          "title": "Label",
          "type": "string"
        },
        "suitable_for": {
          "description": "Appropriate use cases.",
          "items": {
            "type": "string"
          },
          "title": "Suitable For",
          "type": "array"
        },
        "not_suitable_for": {
          "description": "Known exclusions.",
          "items": {
            "type": "string"
          },
          "title": "Not Suitable For",
          "type": "array"
        }
      },
      "required": [
        "label"
      ],
      "title": "FitForPurpose",
      "type": "object"
    },
    "LimitationNote": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "description": "Stable machine-readable limitation code.",
          "title": "Code",
          "type": "string"
        },
        "severity": {
          "$ref": "#/$defs/Severity",
          "default": "warning",
          "description": "Limitation severity."
        },
        "message": {
          "description": "Human-readable limitation text.",
          "title": "Message",
          "type": "string"
        }
      },
      "required": [
        "code",
        "message"
      ],
      "title": "LimitationNote",
      "type": "object"
    },
    "PopulationProfile": {
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "const": "populationProfile.v1",
          "default": "populationProfile.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "population_group": {
          "description": "Population group, for example adult or child.",
          "title": "Population Group",
          "type": "string"
        },
        "body_weight_kg": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Body weight in kilograms.",
          "title": "Body Weight Kg"
        },
        "inhalation_rate_m3_per_hour": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Inhalation rate for inhalation screening.",
          "title": "Inhalation Rate M3 Per Hour"
        },
        "exposed_surface_area_cm2": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Exposed surface area for dermal scenarios.",
          "title": "Exposed Surface Area Cm2"
        },
        "demographic_tags": {
          "description": "Demographic descriptors for auditability.",
          "items": {
            "type": "string"
          },
          "title": "Demographic Tags",
          "type": "array"
        },
        "region": {
          "default": "global",
          "description": "Regional context for defaults or interpretation.",
          "title": "Region",
          "type": "string"
        }
      },
      "required": [
        "population_group"
      ],
      "title": "PopulationProfile",
      "type": "object"
    },
    "ProvenanceBundle": {
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "const": "provenanceBundle.v1",
          "default": "provenanceBundle.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "algorithm_id": {
          "description": "Stable algorithm identifier.",
          "title": "Algorithm Id",
          "type": "string"
        },
        "plugin_id": {
          "description": "Plugin that generated the result.",
          "title": "Plugin Id",
          "type": "string"
        },
        "plugin_version": {
          "description": "Plugin version.",
          "title": "Plugin Version",
          "type": "string"
        },
        "defaults_version": {
          "description": "Defaults pack version.",
          "title": "Defaults Version",
          "type": "string"
        },
        "defaults_hash_sha256": {
          "description": "Hash for the defaults pack in use.",
          "title": "Defaults Hash Sha256",
          "type": "string"
        },
        "generated_at": {
          "description": "ISO-8601 UTC timestamp.",
          "title": "Generated At",
          "type": "string"
        },
        "notes": {
          "description": "Additional provenance notes.",
          "items": {
            "type": "string"
          },
          "title": "Notes",
          "type": "array"
        }
      },
      "required": [
        "algorithm_id",
        "plugin_id",
        "plugin_version",
        "defaults_version",
        "defaults_hash_sha256",
        "generated_at"
      ],
      "title": "ProvenanceBundle",
      "type": "object"
    },
    "QualityFlag": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "description": "Stable machine-readable quality flag code.",
          "title": "Code",
          "type": "string"
        },
        "severity": {
          "$ref": "#/$defs/Severity",
          "default": "info",
          "description": "Quality signal severity."
        },
        "message": {
          "description": "Human-readable quality message.",
          "title": "Message",
          "type": "string"
        }
      },
      "required": [
        "code",
        "message"
      ],
      "title": "QualityFlag",
      "type": "object"
    },
    "Route": {
      "enum": [
        "dermal",
        "oral",
        "inhalation"
      ],
      "title": "Route",
      "type": "string"
    },
    "ScenarioClass": {
      "enum": [
        "screening",
        "aggregate",
        "inhalation",
        "refined",
        "population_distribution"
      ],
      "title": "ScenarioClass",
      "type": "string"
    },
    "ScenarioDose": {
      "additionalProperties": false,
      "properties": {
        "metric": {
          "description": "Dose metric label.",
          "title": "Metric",
          "type": "string"
        },
        "value": {
          "description": "Numeric value for the dose metric.",
          "title": "Value",
          "type": "number"
        },
        "unit": {
          "$ref": "#/$defs/DoseUnit",
          "description": "Canonical dose unit."
        }
      },
      "required": [
        "metric",
        "value",
        "unit"
      ],
      "title": "ScenarioDose",
      "type": "object"
    },
    "Severity": {
      "enum": [
        "info",
        "warning",
        "error"
      ],
      "title": "Severity",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "routeDoseEstimate.v1",
      "default": "routeDoseEstimate.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "chemicalIdentity": {
      "$ref": "#/$defs/ChemicalIdentity",
      "description": "Normalized chemical identity preserved on the route-dose output."
    },
    "route": {
      "$ref": "#/$defs/Route",
      "description": "Route represented by this dose estimate."
    },
    "scenarioClass": {
      "$ref": "#/$defs/ScenarioClass",
      "description": "Scenario class context for the route-dose estimate."
    },
    "dose": {
      "$ref": "#/$defs/ScenarioDose",
      "description": "Canonical dose metric and unit for downstream consumption."
    },
    "sourceScenarioDefinitionId": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Scenario-definition identifier that produced this dose estimate.",
      "title": "Sourcescenariodefinitionid"
    },
    "sourceScenarioId": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Concrete scenario identifier when the dose came from a scenario build.",
      "title": "Sourcescenarioid"
    },
    "sourceConcentrationSurfaceIds": {
      "description": "Upstream concentration-surface identifiers when this dose was derived from environmental concentrations.",
      "items": {
        "type": "string"
      },
      "title": "Sourceconcentrationsurfaceids",
      "type": "array"
    },
    "populationProfile": {
      "anyOf": [
        {
          "$ref": "#/$defs/PopulationProfile"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Population normalization context preserved for downstream review."
    },
    "fitForPurpose": {
      "$ref": "#/$defs/FitForPurpose",
      "description": "Fit-for-purpose statement for the shared route-dose estimate."
    },
    "provenance": {
      "$ref": "#/$defs/ProvenanceBundle",
      "description": "Provenance for the dose estimate and any defaults or adapters used."
    },
    "limitations": {
      "description": "Known limitations that should remain visible downstream.",
      "items": {
        "$ref": "#/$defs/LimitationNote"
      },
      "title": "Limitations",
      "type": "array"
    },
    "qualityFlags": {
      "description": "Quality flags that should remain visible downstream.",
      "items": {
        "$ref": "#/$defs/QualityFlag"
      },
      "title": "Qualityflags",
      "type": "array"
    },
    "notes": {
      "description": "Additional route-dose notes preserved for handoffs.",
      "items": {
        "type": "string"
      },
      "title": "Notes",
      "type": "array"
    }
  },
  "required": [
    "chemicalIdentity",
    "route",
    "scenarioClass",
    "dose",
    "fitForPurpose",
    "provenance"
  ],
  "title": "RouteDoseEstimate",
  "type": "object"
}
