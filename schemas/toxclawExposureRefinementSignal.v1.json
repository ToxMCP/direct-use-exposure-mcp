    "percentDelta": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Percentdelta"
    },
    "materialChange": {
      "title": "Materialchange",
      "type": "boolean"
    },
    "boundaryNote": {
      "title": "Boundarynote",
      "type": "string"
    },
    "workflowHooks": {
      "items": {
        "$ref": "#/$defs/ExposureWorkflowHook"
