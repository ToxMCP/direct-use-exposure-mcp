  "required": [
    "caseId",
    "reportId",
    "contextOfUse",
    "summary",
    "evidenceRecord",
    "reportEvidenceReference",
    "reportSection"
  ],
  "title": "ToxClawEvidenceBundle",
  "type": "object"
