          "type": "string"
        },
        "contentHash": {
          "title": "Contenthash",
          "type": "string"
        },
        "evidenceId": {
          "title": "Evidenceid",
          "type": "string"
        },
        "qualityFlag": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Qualityflag"
        },
        "rawPointer": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Rawpointer"
        },
        "redactionStatus": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Redactionstatus"
        },
        "retrievedAt": {
          "title": "Retrievedat",
          "type": "string"
        },
        "source": {
          "title": "Source",
          "type": "string"
        },
        "sourceRef": {
          "title": "Sourceref",
          "type": "string"
        },
        "summary": {
          "title": "Summary",
          "type": "string"
        },
        "tags": {
          "items": {
            "type": "string"
          },
          "title": "Tags",
          "type": "array"
        },
        "trustLabel": {
          "enum": [
            "module-output",
            "untrusted-document",
            "untrusted-external-data"
          ],
          "title": "Trustlabel",
          "type": "string"
        },
        "type": {
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "contentHash",
        "evidenceId",
        "retrievedAt",
        "source",
        "sourceRef",
        "summary",
        "trustLabel",
        "type"
      ],
      "title": "ToxClawReportEvidenceReference",
      "type": "object"
    },
    "ToxClawReportSection": {
      "additionalProperties": false,
      "properties": {
        "schemaVersion": {
          "const": "toxclawReportSection.v1",
          "default": "toxclawReportSection.v1",
          "title": "Schemaversion",
          "type": "string"
        },
        "body": {
          "title": "Body",
          "type": "string"
        },
        "claims": {
          "items": {
            "$ref": "#/$defs/ToxClawReportClaim"
          },
          "title": "Claims",
          "type": "array"
        },
        "evidenceIds": {
          "items": {
            "type": "string"
          },
          "title": "Evidenceids",
          "type": "array"
        },
        "sectionKey": {
          "title": "Sectionkey",
          "type": "string"
        },
        "title": {
          "title": "Title",
          "type": "string"
        }
      },
      "required": [
        "body",
        "sectionKey",
        "title"
      ],
      "title": "ToxClawReportSection",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "toxclawEvidenceBundle.v1",
      "default": "toxclawEvidenceBundle.v1",
      "title": "Schemaversion",
      "type": "string"
    },
    "caseId": {
      "title": "Caseid",
      "type": "string"
    },
    "reportId": {
      "title": "Reportid",
      "type": "string"
    },
    "contextOfUse": {
      "title": "Contextofuse",
      "type": "string"
    },
    "sourceModule": {
      "const": "exposure-scenario-mcp",
      "default": "exposure-scenario-mcp",
      "title": "Sourcemodule",
      "type": "string"
    },
    "summary": {
      "title": "Summary",
      "type": "string"
    },
    "evidenceRecord": {
      "$ref": "#/$defs/ToxClawEvidenceRecord"
    },
    "reportEvidenceReference": {
      "$ref": "#/$defs/ToxClawReportEvidenceReference"
    },
    "reportSection": {
      "$ref": "#/$defs/ToxClawReportSection"
    }
