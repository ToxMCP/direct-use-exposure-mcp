{
  "$defs": {
    "ArchetypeLibraryTemplate": {
      "additionalProperties": false,
      "properties": {
        "templateId": {
          "title": "Templateid",
          "type": "string"
        },
        "label": {
          "description": "Human-readable archetype label.",
          "title": "Label",
          "type": "string"
        },
        "description": {
          "description": "Why this archetype belongs in the library set.",
          "title": "Description",
          "type": "string"
        },
        "productUseProfile": {
          "$ref": "#/$defs/ProductUseProfile",
          "description": "Product-use template for this archetype."
        },
        "populationProfile": {
          "$ref": "#/$defs/PopulationProfile",
          "description": "Population template for this archetype."
        }
      },
      "required": [
        "templateId",
        "label",
        "description",
        "productUseProfile",
        "populationProfile"
      ],
      "title": "ArchetypeLibraryTemplate",
      "type": "object"
    },
    "PopulationProfile": {
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "const": "populationProfile.v1",
          "default": "populationProfile.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "population_group": {
          "description": "Population group, for example adult or child.",
          "title": "Population Group",
          "type": "string"
        },
        "body_weight_kg": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Body weight in kilograms.",
          "title": "Body Weight Kg"
        },
        "inhalation_rate_m3_per_hour": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Inhalation rate for inhalation screening.",
          "title": "Inhalation Rate M3 Per Hour"
        },
        "exposed_surface_area_cm2": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Exposed surface area for dermal scenarios.",
          "title": "Exposed Surface Area Cm2"
        },
        "demographic_tags": {
          "description": "Demographic descriptors for auditability.",
          "items": {
            "type": "string"
          },
          "title": "Demographic Tags",
          "type": "array"
        },
        "region": {
          "default": "global",
          "description": "Regional context for defaults or interpretation.",
          "title": "Region",
          "type": "string"
        }
      },
      "required": [
        "population_group"
      ],
      "title": "PopulationProfile",
      "type": "object"
    },
    "ProductAmountUnit": {
      "enum": [
        "g",
        "mL"
      ],
      "title": "ProductAmountUnit",
      "type": "string"
    },
    "ProductUseProfile": {
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "const": "productUseProfile.v1",
          "default": "productUseProfile.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "product_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional human-readable product label.",
          "title": "Product Name"
        },
        "product_category": {
          "description": "Product category or PUC-like category.",
          "title": "Product Category",
          "type": "string"
        },
        "physical_form": {
          "description": "Physical form such as cream, liquid, spray, or gel.",
          "title": "Physical Form",
          "type": "string"
        },
        "application_method": {
          "description": "How the product is applied, for example hand_application or trigger_spray.",
          "title": "Application Method",
          "type": "string"
        },
        "retention_type": {
          "default": "leave_on",
          "description": "Retention class such as leave_on or rinse_off.",
          "title": "Retention Type",
          "type": "string"
        },
        "concentration_fraction": {
          "description": "Fraction of the target chemical in the product, 0-1.",
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Concentration Fraction",
          "type": "number"
        },
        "use_amount_per_event": {
          "description": "Product amount used per event.",
          "exclusiveMinimum": 0.0,
          "title": "Use Amount Per Event",
          "type": "number"
        },
        "use_amount_unit": {
          "$ref": "#/$defs/ProductAmountUnit",
          "description": "Unit for the use amount per event."
        },
        "use_events_per_day": {
          "description": "Number of product-use events per day.",
          "exclusiveMinimum": 0.0,
          "title": "Use Events Per Day",
          "type": "number"
        },
        "density_g_per_ml": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Density when the product amount is in mL.",
          "title": "Density G Per Ml"
        },
        "transfer_efficiency": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "maximum": 1.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Route modifier for external transfer.",
          "title": "Transfer Efficiency"
        },
        "retention_factor": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "maximum": 1.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Retention modifier for dermal screening.",
          "title": "Retention Factor"
        },
        "ingestion_fraction": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "maximum": 1.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Fraction of chemical mass incidentally or directly ingested.",
          "title": "Ingestion Fraction"
        },
        "aerosolized_fraction": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "maximum": 1.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Fraction of chemical mass released to air.",
          "title": "Aerosolized Fraction"
        },
        "room_volume_m3": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Indoor room volume for inhalation screening.",
          "title": "Room Volume M3"
        },
        "air_exchange_rate_per_hour": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Air exchange rate for inhalation screening.",
          "title": "Air Exchange Rate Per Hour"
        },
        "exposure_duration_hours": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Duration of exposure per event.",
          "title": "Exposure Duration Hours"
        }
      },
      "required": [
        "product_category",
        "physical_form",
        "application_method",
        "concentration_fraction",
        "use_amount_per_event",
        "use_amount_unit",
        "use_events_per_day"
      ],
      "title": "ProductUseProfile",
      "type": "object"
    },
    "Route": {
      "enum": [
        "dermal",
        "oral",
        "inhalation"
      ],
      "title": "Route",
      "type": "string"
    },
    "ScenarioClass": {
      "enum": [
        "screening",
        "aggregate",
        "inhalation",
        "refined",
        "population_distribution"
      ],
      "title": "ScenarioClass",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "setId": {
      "title": "Setid",
      "type": "string"
    },
    "label": {
      "description": "Human-readable library-set label.",
      "title": "Label",
      "type": "string"
    },
    "description": {
      "description": "What this set is intended to represent.",
      "title": "Description",
      "type": "string"
    },
    "route": {
      "$ref": "#/$defs/Route",
      "description": "Common route across the archetypes in this set."
    },
    "scenarioClass": {
      "$ref": "#/$defs/ScenarioClass"
    },
    "chemicalScope": {
      "const": "caller_supplied",
      "default": "caller_supplied",
      "description": "Whether the caller must inject the target chemical identity.",
      "title": "Chemicalscope",
      "type": "string"
    },
    "intendedUse": {
      "description": "Short fit-for-purpose statement for this set.",
      "title": "Intendeduse",
      "type": "string"
    },
    "driverParameters": {
      "items": {
        "type": "string"
      },
      "title": "Driverparameters",
      "type": "array"
    },
    "interpretationNotes": {
      "items": {
        "type": "string"
      },
      "title": "Interpretationnotes",
      "type": "array"
    },
    "limitations": {
      "items": {
        "type": "string"
      },
      "title": "Limitations",
      "type": "array"
    },
    "archetypes": {
      "description": "Packaged archetype templates for this set.",
      "items": {
        "$ref": "#/$defs/ArchetypeLibraryTemplate"
      },
      "minItems": 2,
      "title": "Archetypes",
      "type": "array"
    }
  },
  "required": [
    "setId",
    "label",
    "description",
    "route",
    "scenarioClass",
    "intendedUse",
    "archetypes"
  ],
  "title": "ArchetypeLibrarySet",
  "type": "object"
}
