    },
    "barrierMaterial": {
      "$ref": "#/$defs/WorkerDermalBarrierMaterial",
      "default": "unknown"
    },
    "controlMeasures": {
      "items": {
        "type": "string"
      },
      "title": "Controlmeasures",
      "type": "array"
    },
    "surfaceLoadingContext": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Surfaceloadingcontext"
    },
    "skinCondition": {
      "$ref": "#/$defs/WorkerSkinCondition",
      "default": "unknown"
    },
    "notes": {
      "items": {
        "type": "string"
      },
      "title": "Notes",
      "type": "array"
    }
