{
  "$defs": {
    "DependencyHandlingStrategy": {
      "enum": [
        "scenario_packaged",
        "conditional_model_required",
        "joint_model_required",
        "not_quantified"
      ],
      "title": "DependencyHandlingStrategy",
      "type": "string"
    },
    "DependencyRelationship": {
      "enum": [
        "structural",
        "physiological",
        "behavioral",
        "mechanistic",
        "scenario_package"
      ],
      "title": "DependencyRelationship",
      "type": "string"
    },
    "DriverProfileFamily": {
      "enum": [
        "use_burden",
        "formulation_strength",
        "microenvironment",
        "ingestion_regimen"
      ],
      "title": "DriverProfileFamily",
      "type": "string"
    },
    "ProbabilityBoundSupportPointDefinition": {
      "additionalProperties": false,
      "properties": {
        "pointId": {
          "title": "Pointid",
          "type": "string"
        },
        "parameterValue": {
          "title": "Parametervalue",
          "type": "number"
        },
        "cumulativeProbabilityLower": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Cumulativeprobabilitylower",
          "type": "number"
        },
        "cumulativeProbabilityUpper": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Cumulativeprobabilityupper",
          "type": "number"
        },
        "note": {
          "title": "Note",
          "type": "string"
        }
      },
      "required": [
        "pointId",
        "parameterValue",
        "cumulativeProbabilityLower",
        "cumulativeProbabilityUpper",
        "note"
      ],
      "title": "ProbabilityBoundSupportPointDefinition",
      "type": "object"
    },
    "Route": {
      "enum": [
        "dermal",
        "oral",
        "inhalation"
      ],
      "title": "Route",
      "type": "string"
    },
    "ScenarioClass": {
      "enum": [
        "screening",
        "aggregate",
        "inhalation",
        "refined",
        "population_distribution"
      ],
      "title": "ScenarioClass",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "profileId": {
      "title": "Profileid",
      "type": "string"
    },
    "label": {
      "description": "Human-readable driver-profile label.",
      "title": "Label",
      "type": "string"
    },
    "description": {
      "description": "What this driver profile is intended to represent.",
      "title": "Description",
      "type": "string"
    },
    "parameterName": {
      "title": "Parametername",
      "type": "string"
    },
    "route": {
      "$ref": "#/$defs/Route",
      "description": "Route for which the driver profile applies."
    },
    "scenarioClass": {
      "$ref": "#/$defs/ScenarioClass"
    },
    "archetypeLibrarySetId": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Archetypelibrarysetid"
    },
    "productFamily": {
      "description": "Named product-family or use-family for the driver profile.",
      "title": "Productfamily",
      "type": "string"
    },
    "driverFamily": {
      "$ref": "#/$defs/DriverProfileFamily",
      "description": "Curated taxonomy family for the varied driver."
    },
    "dependencyCluster": {
      "description": "Named dependency cluster surrounding the varied driver.",
      "title": "Dependencycluster",
      "type": "string"
    },
    "fixedAxes": {
      "description": "Related axes intentionally held fixed while the driver varies.",
      "items": {
        "type": "string"
      },
      "title": "Fixedaxes",
      "type": "array"
    },
    "relationshipType": {
      "$ref": "#/$defs/DependencyRelationship",
      "description": "Dependency relationship classification for the profile context."
    },
    "handlingStrategy": {
      "$ref": "#/$defs/DependencyHandlingStrategy",
      "description": "How unmodeled dependencies are handled for the profile."
    },
    "applicability": {
      "additionalProperties": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "number"
          },
          {
            "type": "integer"
          },
          {
            "type": "boolean"
          },
          {
            "type": "null"
          }
        ]
      },
      "title": "Applicability",
      "type": "object"
    },
    "supportPoints": {
      "items": {
        "$ref": "#/$defs/ProbabilityBoundSupportPointDefinition"
      },
      "minItems": 2,
      "title": "Supportpoints",
      "type": "array"
    },
    "limitations": {
      "items": {
        "type": "string"
      },
      "title": "Limitations",
      "type": "array"
    }
  },
  "required": [
    "profileId",
    "label",
    "description",
    "parameterName",
    "route",
    "scenarioClass",
    "productFamily",
    "driverFamily",
    "dependencyCluster",
    "relationshipType",
    "handlingStrategy",
    "supportPoints"
  ],
  "title": "ProbabilityBoundsDriverProfile",
  "type": "object"
}
