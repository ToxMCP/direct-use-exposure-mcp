{
  "$defs": {
    "LimitationNote": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "description": "Stable machine-readable limitation code.",
          "title": "Code",
          "type": "string"
        },
        "severity": {
          "$ref": "#/$defs/Severity",
          "default": "warning",
          "description": "Limitation severity."
        },
        "message": {
          "description": "Human-readable limitation text.",
          "title": "Message",
          "type": "string"
        }
      },
      "required": [
        "code",
        "message"
      ],
      "title": "LimitationNote",
      "type": "object"
    },
    "ProvenanceBundle": {
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "const": "provenanceBundle.v1",
          "default": "provenanceBundle.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "algorithm_id": {
          "description": "Stable algorithm identifier.",
          "title": "Algorithm Id",
          "type": "string"
        },
        "plugin_id": {
          "description": "Plugin that generated the result.",
          "title": "Plugin Id",
          "type": "string"
        },
        "plugin_version": {
          "description": "Plugin version.",
          "title": "Plugin Version",
          "type": "string"
        },
        "defaults_version": {
          "description": "Defaults pack version.",
          "title": "Defaults Version",
          "type": "string"
        },
        "defaults_hash_sha256": {
          "description": "Hash for the defaults pack in use.",
          "title": "Defaults Hash Sha256",
          "type": "string"
        },
        "generated_at": {
          "description": "ISO-8601 UTC timestamp.",
          "title": "Generated At",
          "type": "string"
        },
        "notes": {
          "description": "Additional provenance notes.",
          "items": {
            "type": "string"
          },
          "title": "Notes",
          "type": "array"
        }
      },
      "required": [
        "algorithm_id",
        "plugin_id",
        "plugin_version",
        "defaults_version",
        "defaults_hash_sha256",
        "generated_at"
      ],
      "title": "ProvenanceBundle",
      "type": "object"
    },
    "QualityFlag": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "description": "Stable machine-readable quality flag code.",
          "title": "Code",
          "type": "string"
        },
        "severity": {
          "$ref": "#/$defs/Severity",
          "default": "info",
          "description": "Quality signal severity."
        },
        "message": {
          "description": "Human-readable quality message.",
          "title": "Message",
          "type": "string"
        }
      },
      "required": [
        "code",
        "message"
      ],
      "title": "QualityFlag",
      "type": "object"
    },
    "Severity": {
      "enum": [
        "info",
        "warning",
        "error"
      ],
      "title": "Severity",
      "type": "string"
    },
    "WorkerDermalAbsorbedDoseTaskEnvelope": {
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "const": "workerDermalAbsorbedDoseTaskEnvelope.v1",
          "default": "workerDermalAbsorbedDoseTaskEnvelope.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "adapterName": {
          "default": "worker_dermal_absorption_ppe_adapter",
          "title": "Adaptername",
          "type": "string"
        },
        "adapterVersion": {
          "default": "0.2.1",
          "title": "Adapterversion",
          "type": "string"
        },
        "contactProfile": {
          "title": "Contactprofile",
          "type": "string"
        },
        "ppeProfile": {
          "title": "Ppeprofile",
          "type": "string"
        },
        "bodyZoneProfile": {
          "title": "Bodyzoneprofile",
          "type": "string"
        },
        "determinantTemplateMatch": {
          "$ref": "#/$defs/WorkerDermalDeterminantTemplateMatch"
        },
        "chemicalContext": {
          "anyOf": [
            {
              "$ref": "#/$defs/WorkerDermalChemicalContext"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "taskSummary": {
          "items": {
            "type": "string"
          },
          "title": "Tasksummary",
          "type": "array"
        },
        "dermalInputs": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              },
              {
                "type": "integer"
              },
              {
                "type": "boolean"
              },
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "items": {},
                "type": "array"
              },
              {
                "type": "null"
              }
            ]
          },
          "title": "Dermalinputs",
          "type": "object"
        },
        "screeningHandoffSummary": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              },
              {
                "type": "integer"
              },
              {
                "type": "boolean"
              },
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "items": {},
                "type": "array"
              },
              {
                "type": "null"
              }
            ]
          },
          "title": "Screeninghandoffsummary",
          "type": "object"
        }
      },
      "required": [
        "contactProfile",
        "ppeProfile",
        "bodyZoneProfile",
        "determinantTemplateMatch"
      ],
      "title": "WorkerDermalAbsorbedDoseTaskEnvelope",
      "type": "object"
    },
    "WorkerDermalChemicalContext": {
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "const": "workerDermalChemicalContext.v1",
          "default": "workerDermalChemicalContext.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "vaporPressureMmhg": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Vapor pressure in mmHg for bounded volatility-aware calculations.",
          "title": "Vaporpressuremmhg"
        },
        "molecularWeightGPerMol": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Molecular weight in g/mol for bounded thermodynamic conversions.",
          "title": "Molecularweightgpermol"
        },
        "logKow": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "logKow descriptor preserved for chemistry-aware screening refinements.",
          "title": "Logkow"
        },
        "waterSolubilityMgPerL": {
          "anyOf": [
            {
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Water solubility in mg/L preserved for chemistry-aware screening refinements.",
          "title": "Watersolubilitymgperl"
        }
      },
      "title": "WorkerDermalChemicalContext",
      "type": "object"
    },
    "WorkerDermalDeterminantTemplateMatch": {
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "const": "workerDermalDeterminantTemplateMatch.v1",
          "default": "workerDermalDeterminantTemplateMatch.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "templateId": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Templateid"
        },
        "templateLabel": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Templatelabel"
        },
        "alignmentStatus": {
          "$ref": "#/$defs/WorkerDermalTemplateAlignmentStatus",
          "default": "none"
        },
        "matchScore": {
          "default": 0.0,
          "title": "Matchscore",
          "type": "number"
        },
        "matchBasis": {
          "items": {
            "type": "string"
          },
          "title": "Matchbasis",
          "type": "array"
        },
        "determinantRecommendations": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              },
              {
                "type": "integer"
              },
              {
                "type": "boolean"
              },
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "items": {},
                "type": "array"
              },
              {
                "type": "null"
              }
            ]
          },
          "title": "Determinantrecommendations",
          "type": "object"
        },
        "sourceBasis": {
          "items": {
            "type": "string"
          },
          "title": "Sourcebasis",
          "type": "array"
        },
        "reviewNotes": {
          "items": {
            "type": "string"
          },
          "title": "Reviewnotes",
          "type": "array"
        }
      },
      "title": "WorkerDermalDeterminantTemplateMatch",
      "type": "object"
    },
    "WorkerDermalModelFamily": {
      "enum": [
        "dermal_absorption_ppe",
        "ih_skinperm"
      ],
      "title": "WorkerDermalModelFamily",
      "type": "string"
    },
    "WorkerDermalTemplateAlignmentStatus": {
      "enum": [
        "aligned",
        "partial",
        "heuristic",
        "none"
      ],
      "title": "WorkerDermalTemplateAlignmentStatus",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "workerDermalAbsorbedDoseAdapterIngestResult.v1",
      "default": "workerDermalAbsorbedDoseAdapterIngestResult.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "supportedByAdapter": {
      "title": "Supportedbyadapter",
      "type": "boolean"
    },
    "readyForAdapterExecution": {
      "title": "Readyforadapterexecution",
      "type": "boolean"
    },
    "manualReviewRequired": {
      "title": "Manualreviewrequired",
      "type": "boolean"
    },
    "resolvedAdapter": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Resolvedadapter"
    },
    "targetModelFamily": {
      "$ref": "#/$defs/WorkerDermalModelFamily"
    },
    "dermalTaskEnvelope": {
      "anyOf": [
        {
          "$ref": "#/$defs/WorkerDermalAbsorbedDoseTaskEnvelope"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "qualityFlags": {
      "items": {
        "$ref": "#/$defs/QualityFlag"
      },
      "title": "Qualityflags",
      "type": "array"
    },
    "limitations": {
      "items": {
        "$ref": "#/$defs/LimitationNote"
      },
      "title": "Limitations",
      "type": "array"
    },
    "provenance": {
      "$ref": "#/$defs/ProvenanceBundle"
    }
  },
  "required": [
    "supportedByAdapter",
    "readyForAdapterExecution",
    "manualReviewRequired",
    "targetModelFamily",
    "provenance"
  ],
  "title": "WorkerDermalAbsorbedDoseAdapterIngestResult",
  "type": "object"
