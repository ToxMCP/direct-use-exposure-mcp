{
  "$defs": {
    "LimitationNote": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "description": "Stable machine-readable limitation code.",
          "title": "Code",
          "type": "string"
        },
        "severity": {
          "$ref": "#/$defs/Severity",
          "default": "warning",
          "description": "Limitation severity."
        },
        "message": {
          "description": "Human-readable limitation text.",
          "title": "Message",
          "type": "string"
        }
      },
      "required": [
        "code",
        "message"
      ],
      "title": "LimitationNote",
      "type": "object"
    },
    "PbpkCompatibilityReport": {
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "const": "pbpkCompatibilityReport.v1",
          "default": "pbpkCompatibilityReport.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "source_scenario_id": {
          "description": "Source scenario identifier.",
          "title": "Source Scenario Id",
          "type": "string"
        },
        "compatible": {
          "description": "Whether the object is PBPK-compatible.",
          "title": "Compatible",
          "type": "boolean"
        },
        "target_tool": {
          "const": "ingest_external_pbpk_bundle",
          "default": "ingest_external_pbpk_bundle",
          "description": "PBPK MCP tool evaluated for downstream readiness.",
          "title": "Target Tool",
          "type": "string"
        },
        "checked_route": {
          "$ref": "#/$defs/Route",
          "description": "Route checked for compatibility."
        },
        "checked_dose_unit": {
          "description": "Dose unit checked for compatibility.",
          "title": "Checked Dose Unit",
          "type": "string"
        },
        "ready_for_external_pbpk_import": {
          "description": "Whether the scenario alone contains enough data to populate the PBPK external-import path without additional PBPK execution outputs.",
          "title": "Ready For External Pbpk Import",
          "type": "boolean"
        },
        "supported_pbpk_objects": {
          "description": "Published PBPK object families this scenario can prefill or support.",
          "items": {
            "type": "string"
          },
          "title": "Supported Pbpk Objects",
          "type": "array"
        },
        "missing_external_bundle_fields": {
          "description": "PBPK external-import fields still missing for a richer downstream handoff.",
          "items": {
            "type": "string"
          },
          "title": "Missing External Bundle Fields",
          "type": "array"
        },
        "checked_fields": {
          "description": "Fields explicitly checked during compatibility validation.",
          "items": {
            "type": "string"
          },
          "title": "Checked Fields",
          "type": "array"
        },
        "issues": {
          "description": "Compatibility issues or warnings.",
          "items": {
            "$ref": "#/$defs/LimitationNote"
          },
          "title": "Issues",
          "type": "array"
        },
        "recommended_next_steps": {
          "description": "Concrete actions to strengthen the PBPK handoff.",
          "items": {
            "type": "string"
          },
          "title": "Recommended Next Steps",
          "type": "array"
        }
      },
      "required": [
        "source_scenario_id",
        "compatible",
        "checked_route",
        "checked_dose_unit",
        "ready_for_external_pbpk_import"
      ],
      "title": "PbpkCompatibilityReport",
      "type": "object"
    },
    "PbpkExternalArtifact": {
      "additionalProperties": false,
      "properties": {
        "type": {
          "minLength": 1,
          "title": "Type",
          "type": "string"
        },
        "path": {
          "minLength": 1,
          "title": "Path",
          "type": "string"
        },
        "checksum": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Checksum"
        },
        "title": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Title"
        }
      },
      "required": [
        "type",
        "path"
      ],
      "title": "PbpkExternalArtifact",
      "type": "object"
    },
    "PbpkExternalImportBundle": {
      "additionalProperties": false,
      "properties": {
        "schemaVersion": {
          "const": "pbpkExternalImportBundle.v1",
          "default": "pbpkExternalImportBundle.v1",
          "title": "Schemaversion",
          "type": "string"
        },
        "sourcePlatform": {
          "title": "Sourceplatform",
          "type": "string"
        },
        "sourceVersion": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Sourceversion"
        },
        "modelName": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Modelname"
        },
        "modelType": {
          "title": "Modeltype",
          "type": "string"
        },
        "executionDate": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Executiondate"
        },
        "runId": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Runid"
        },
        "operator": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Operator"
        },
        "sponsor": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Sponsor"
        },
        "rawArtifacts": {
          "items": {
            "$ref": "#/$defs/PbpkExternalArtifact"
          },
          "title": "Rawartifacts",
          "type": "array"
        },
        "assessmentContext": {
          "additionalProperties": true,
          "title": "Assessmentcontext",
          "type": "object"
        },
        "chemicalIdentity": {
          "additionalProperties": true,
          "title": "Chemicalidentity",
          "type": "object"
        },
        "supportingHandoffs": {
          "additionalProperties": true,
          "title": "Supportinghandoffs",
          "type": "object"
        },
        "internalExposure": {
          "additionalProperties": true,
          "title": "Internalexposure",
          "type": "object"
        },
        "qualification": {
          "additionalProperties": true,
          "title": "Qualification",
          "type": "object"
        },
        "uncertainty": {
          "additionalProperties": true,
          "title": "Uncertainty",
          "type": "object"
        },
        "uncertaintyRegister": {
          "additionalProperties": true,
          "title": "Uncertaintyregister",
          "type": "object"
        },
        "pod": {
          "additionalProperties": true,
          "title": "Pod",
          "type": "object"
        },
        "trueDoseAdjustment": {
          "additionalProperties": true,
          "title": "Truedoseadjustment",
          "type": "object"
        },
        "comparisonMetric": {
          "default": "cmax",
          "title": "Comparisonmetric",
          "type": "string"
        }
      },
      "required": [
        "sourcePlatform",
        "modelType"
      ],
      "title": "PbpkExternalImportBundle",
      "type": "object"
    },
    "PbpkExternalImportRequest": {
      "additionalProperties": false,
      "properties": {
        "sourcePlatform": {
          "title": "Sourceplatform",
          "type": "string"
        },
        "sourceVersion": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Sourceversion"
        },
        "modelName": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Modelname"
        },
        "modelType": {
          "title": "Modeltype",
          "type": "string"
        },
        "executionDate": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Executiondate"
        },
        "runId": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Runid"
        },
        "operator": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Operator"
        },
        "sponsor": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Sponsor"
        },
        "rawArtifacts": {
          "items": {
            "$ref": "#/$defs/PbpkExternalArtifact"
          },
          "title": "Rawartifacts",
          "type": "array"
        },
        "assessmentContext": {
          "additionalProperties": true,
          "title": "Assessmentcontext",
          "type": "object"
        },
        "internalExposure": {
          "additionalProperties": true,
          "title": "Internalexposure",
          "type": "object"
        },
        "qualification": {
          "additionalProperties": true,
          "title": "Qualification",
          "type": "object"
        },
        "uncertainty": {
          "additionalProperties": true,
          "title": "Uncertainty",
          "type": "object"
        },
        "uncertaintyRegister": {
          "additionalProperties": true,
          "title": "Uncertaintyregister",
          "type": "object"
        },
        "pod": {
          "additionalProperties": true,
          "title": "Pod",
          "type": "object"
        },
        "trueDoseAdjustment": {
          "additionalProperties": true,
          "title": "Truedoseadjustment",
          "type": "object"
        },
        "comparisonMetric": {
          "default": "cmax",
          "title": "Comparisonmetric",
          "type": "string"
        }
      },
      "required": [
        "sourcePlatform",
        "modelType"
      ],
      "title": "PbpkExternalImportRequest",
      "type": "object"
    },
    "PbpkExternalImportToolCall": {
      "additionalProperties": false,
      "properties": {
        "schemaVersion": {
          "const": "pbpkExternalImportToolCall.v1",
          "default": "pbpkExternalImportToolCall.v1",
          "title": "Schemaversion",
          "type": "string"
        },
        "toolName": {
          "const": "ingest_external_pbpk_bundle",
          "default": "ingest_external_pbpk_bundle",
          "title": "Toolname",
          "type": "string"
        },
        "arguments": {
          "$ref": "#/$defs/PbpkExternalImportRequest"
        }
      },
      "required": [
        "arguments"
      ],
      "title": "PbpkExternalImportToolCall",
      "type": "object"
    },
    "Route": {
      "enum": [
        "dermal",
        "oral",
        "inhalation"
      ],
      "title": "Route",
      "type": "string"
    },
    "Severity": {
      "enum": [
        "info",
        "warning",
        "error"
      ],
      "title": "Severity",
      "type": "string"
    },
    "ToxClawPbpkModuleParams": {
      "additionalProperties": false,
      "properties": {
        "schemaVersion": {
          "const": "toxclawPbpkModuleParams.v1",
          "default": "toxclawPbpkModuleParams.v1",
          "title": "Schemaversion",
          "type": "string"
        },
        "ingestToolName": {
          "const": "ingest_external_pbpk_bundle",
          "default": "ingest_external_pbpk_bundle",
          "title": "Ingesttoolname",
          "type": "string"
        },
        "arguments": {
          "$ref": "#/$defs/PbpkExternalImportRequest"
        },
        "chemicalIdentity": {
          "additionalProperties": true,
          "title": "Chemicalidentity",
          "type": "object"
        },
        "supportingHandoffs": {
          "additionalProperties": true,
          "title": "Supportinghandoffs",
          "type": "object"
        }
      },
      "required": [
        "arguments"
      ],
      "title": "ToxClawPbpkModuleParams",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "pbpkExternalImportPackage.v1",
      "default": "pbpkExternalImportPackage.v1",
      "title": "Schemaversion",
      "type": "string"
    },
    "ingestToolName": {
      "const": "ingest_external_pbpk_bundle",
      "default": "ingest_external_pbpk_bundle",
      "title": "Ingesttoolname",
      "type": "string"
    },
    "bundle": {
      "$ref": "#/$defs/PbpkExternalImportBundle"
    },
    "requestPayload": {
      "$ref": "#/$defs/PbpkExternalImportRequest"
    },
    "toolCall": {
      "$ref": "#/$defs/PbpkExternalImportToolCall"
    },
    "toxclawModuleParams": {
      "$ref": "#/$defs/ToxClawPbpkModuleParams"
    },
    "compatibilityReport": {
      "$ref": "#/$defs/PbpkCompatibilityReport"
    }
  },
  "required": [
    "bundle",
    "requestPayload",
    "toolCall",
    "toxclawModuleParams",
    "compatibilityReport"
  ],
  "title": "PbpkExternalImportPackage",
  "type": "object"
}
