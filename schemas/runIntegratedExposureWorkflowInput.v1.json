{
  "$defs": {
    "AirflowDirectionality": {
      "enum": [
        "quiescent",
        "cross_draft",
        "source_to_breathing_zone",
        "breathing_zone_to_source",
        "general_room_mixing"
      ],
      "title": "AirflowDirectionality",
      "type": "string"
    },
    "CompToxChemicalRecord": {
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "const": "compToxChemicalRecord.v1",
          "default": "compToxChemicalRecord.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "chemical_id": {
          "description": "Stable CompTox chemical identifier.",
          "title": "Chemical Id",
          "type": "string"
        },
        "preferred_name": {
          "description": "Preferred chemical name.",
          "title": "Preferred Name",
          "type": "string"
        },
        "casrn": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "CAS Registry Number when known.",
          "title": "Casrn"
        },
        "product_use_categories": {
          "description": "Relevant product-use categories discovered upstream.",
          "items": {
            "type": "string"
          },
          "title": "Product Use Categories",
          "type": "array"
        },
        "physchem_summary": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              },
              {
                "type": "integer"
              },
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ]
          },
          "description": "Physicochemical context that can support downstream scenario interpretation.",
          "title": "Physchem Summary",
          "type": "object"
        },
        "evidence_sources": {
          "description": "Upstream evidence or record identifiers backing the CompTox record.",
          "items": {
            "type": "string"
          },
          "title": "Evidence Sources",
          "type": "array"
        }
      },
      "required": [
        "chemical_id",
        "preferred_name"
      ],
      "title": "CompToxChemicalRecord",
      "type": "object"
    },
    "ConsExpoEvidenceRecord": {
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "const": "consExpoEvidenceRecord.v1",
          "default": "consExpoEvidenceRecord.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "chemical_id": {
          "description": "Stable chemical identifier shared with the request.",
          "title": "Chemical Id",
          "type": "string"
        },
        "preferred_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Preferred chemical name when the ConsExpo source is already tied to identity.",
          "title": "Preferred Name"
        },
        "casrn": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "CAS Registry Number when known.",
          "title": "Casrn"
        },
        "factSheetId": {
          "title": "Factsheetid",
          "type": "string"
        },
        "factSheetTitle": {
          "title": "Factsheettitle",
          "type": "string"
        },
        "factSheetVersion": {
          "title": "Factsheetversion",
          "type": "string"
        },
        "factSheetLocator": {
          "title": "Factsheetlocator",
          "type": "string"
        },
        "productGroup": {
          "description": "ConsExpo product-group family such as cosmetics or pest_control_products.",
          "title": "Productgroup",
          "type": "string"
        },
        "productSubgroup": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional narrower ConsExpo subgroup or scenario label.",
          "title": "Productsubgroup"
        },
        "modelFamily": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional ConsExpo model family such as spray or direct_application.",
          "title": "Modelfamily"
        },
        "supportedRoutes": {
          "description": "Routes explicitly supported by the cited ConsExpo source.",
          "items": {
            "$ref": "#/$defs/Route"
          },
          "title": "Supportedroutes",
          "type": "array"
        },
        "physical_forms": {
          "description": "Physical forms supported by the ConsExpo source.",
          "items": {
            "type": "string"
          },
          "title": "Physical Forms",
          "type": "array"
        },
        "application_methods": {
          "description": "Application methods supported by the ConsExpo source.",
          "items": {
            "type": "string"
          },
          "title": "Application Methods",
          "type": "array"
        },
        "retention_types": {
          "description": "Retention or contact semantics supported by the ConsExpo source.",
          "items": {
            "type": "string"
          },
          "title": "Retention Types",
          "type": "array"
        },
        "region_scopes": {
          "description": "Regions where the ConsExpo evidence is considered applicable.",
          "items": {
            "type": "string"
          },
          "title": "Region Scopes",
          "type": "array"
        },
        "jurisdictions": {
          "description": "Jurisdictions or programs where the ConsExpo evidence is relevant.",
          "items": {
            "type": "string"
          },
          "title": "Jurisdictions",
          "type": "array"
        },
        "physchem_summary": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              },
              {
                "type": "integer"
              },
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ]
          },
          "description": "Optional physicochemical context preserved from the ConsExpo source.",
          "title": "Physchem Summary",
          "type": "object"
        },
        "evidence_sources": {
          "description": "Stable upstream evidence references backing the ConsExpo record.",
          "items": {
            "type": "string"
          },
          "title": "Evidence Sources",
          "type": "array"
        },
        "notes": {
          "description": "Additional notes preserved from the ConsExpo source.",
          "items": {
            "type": "string"
          },
          "title": "Notes",
          "type": "array"
        }
      },
      "required": [
        "chemical_id",
        "factSheetId",
        "factSheetTitle",
        "factSheetVersion",
        "factSheetLocator",
        "productGroup"
      ],
      "title": "ConsExpoEvidenceRecord",
      "type": "object"
    },
    "ExposureScenarioRequest": {
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "const": "exposureScenarioRequest.v1",
          "default": "exposureScenarioRequest.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "chemical_id": {
          "description": "Stable chemical identifier.",
          "title": "Chemical Id",
          "type": "string"
        },
        "chemical_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional chemical name.",
          "title": "Chemical Name"
        },
        "route": {
          "$ref": "#/$defs/Route",
          "description": "Requested exposure route."
        },
        "scenario_class": {
          "$ref": "#/$defs/ScenarioClass",
          "default": "screening",
          "description": "Requested scenario class."
        },
        "product_use_profile": {
          "$ref": "#/$defs/ProductUseProfile",
          "description": "Product and use-context profile."
        },
        "population_profile": {
          "$ref": "#/$defs/PopulationProfile",
          "description": "Population profile for the exposed cohort."
        },
        "assumption_overrides": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              },
              {
                "type": "integer"
              },
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ]
          },
          "description": "Additional explicit overrides for auditability.",
          "title": "Assumption Overrides",
          "type": "object"
        }
      },
      "required": [
        "chemical_id",
        "route",
        "product_use_profile",
        "population_profile"
      ],
      "title": "ExposureScenarioRequest",
      "type": "object"
    },
    "InhalationScenarioRequest": {
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "const": "exposureScenarioRequest.v1",
          "default": "exposureScenarioRequest.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "chemical_id": {
          "description": "Stable chemical identifier.",
          "title": "Chemical Id",
          "type": "string"
        },
        "chemical_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional chemical name.",
          "title": "Chemical Name"
        },
        "route": {
          "$ref": "#/$defs/Route",
          "description": "Requested exposure route."
        },
        "scenario_class": {
          "$ref": "#/$defs/ScenarioClass",
          "default": "inhalation",
          "description": "Requested scenario class."
        },
        "product_use_profile": {
          "$ref": "#/$defs/ProductUseProfile",
          "description": "Product and use-context profile."
        },
        "population_profile": {
          "$ref": "#/$defs/PopulationProfile",
          "description": "Population profile for the exposed cohort."
        },
        "assumption_overrides": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              },
              {
                "type": "integer"
              },
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ]
          },
          "description": "Additional explicit overrides for auditability.",
          "title": "Assumption Overrides",
          "type": "object"
        },
        "requestedTier": {
          "$ref": "#/$defs/TierLevel",
          "default": "tier_0",
          "description": "Requested inhalation modeling tier. Tier 1 is reserved as a future contract hook and is not implemented in v0.1.0."
        }
      },
      "required": [
        "chemical_id",
        "route",
        "product_use_profile",
        "population_profile"
      ],
      "title": "InhalationScenarioRequest",
      "type": "object"
    },
    "InhalationTier1ScenarioRequest": {
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "const": "inhalationTier1ScenarioRequest.v1",
          "default": "inhalationTier1ScenarioRequest.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "chemical_id": {
          "description": "Stable chemical identifier.",
          "title": "Chemical Id",
          "type": "string"
        },
        "chemical_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional chemical name.",
          "title": "Chemical Name"
        },
        "route": {
          "$ref": "#/$defs/Route",
          "description": "Requested exposure route."
        },
        "scenario_class": {
          "$ref": "#/$defs/ScenarioClass",
          "default": "inhalation",
          "description": "Requested scenario class for the future Tier 1 inhalation family."
        },
        "product_use_profile": {
          "$ref": "#/$defs/ProductUseProfile",
          "description": "Product and use-context profile."
        },
        "population_profile": {
          "$ref": "#/$defs/PopulationProfile",
          "description": "Population profile for the exposed cohort."
        },
        "assumption_overrides": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              },
              {
                "type": "integer"
              },
              {
                "type": "boolean"
              },
              {
                "type": "null"
              }
            ]
          },
          "description": "Additional explicit overrides for auditability.",
          "title": "Assumption Overrides",
          "type": "object"
        },
        "requestedTier": {
          "const": "tier_1",
          "default": "tier_1",
          "description": "Tier 1 inhalation request surface for a future near-field/far-field screening model family.",
          "title": "Requestedtier",
          "type": "string"
        },
        "source_distance_m": {
          "description": "Distance from the breathing zone to the active spray source.",
          "exclusiveMinimum": 0.0,
          "title": "Source Distance M",
          "type": "number"
        },
        "spray_duration_seconds": {
          "description": "Active spray emission duration for each use event.",
          "exclusiveMinimum": 0.0,
          "title": "Spray Duration Seconds",
          "type": "number"
        },
        "near_field_volume_m3": {
          "description": "Local near-field control volume around the user.",
          "exclusiveMinimum": 0.0,
          "title": "Near Field Volume M3",
          "type": "number"
        },
        "airflow_directionality": {
          "$ref": "#/$defs/AirflowDirectionality",
          "description": "Directional airflow context near the source and breathing zone."
        },
        "particle_size_regime": {
          "$ref": "#/$defs/ParticleSizeRegime",
          "description": "Spray droplet or aerosol size regime used for screening semantics."
        }
      },
      "required": [
        "chemical_id",
        "route",
        "product_use_profile",
        "population_profile",
        "source_distance_m",
        "spray_duration_seconds",
        "near_field_volume_m3",
        "airflow_directionality",
        "particle_size_regime"
      ],
      "title": "InhalationTier1ScenarioRequest",
      "type": "object"
    },
    "ParticleSizeRegime": {
      "enum": [
        "fine_aerosol",
        "mixed_spray",
        "coarse_spray"
      ],
      "title": "ParticleSizeRegime",
      "type": "string"
    },
    "PopulationProfile": {
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "const": "populationProfile.v1",
          "default": "populationProfile.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "population_group": {
          "description": "Population group, for example adult or child.",
          "title": "Population Group",
          "type": "string"
        },
        "body_weight_kg": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Body weight in kilograms.",
          "title": "Body Weight Kg"
        },
        "inhalation_rate_m3_per_hour": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Inhalation rate for inhalation screening.",
          "title": "Inhalation Rate M3 Per Hour"
        },
        "exposed_surface_area_cm2": {
          "anyOf": [
            {
              "exclusiveMinimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Exposed surface area for dermal scenarios.",
          "title": "Exposed Surface Area Cm2"
        },
        "demographic_tags": {
          "description": "Demographic descriptors for auditability.",
          "items": {
            "type": "string"
          },
          "title": "Demographic Tags",
          "type": "array"
        },
        "region": {
          "default": "global",
          "description": "Regional context for defaults or interpretation.",
          "title": "Region",
          "type": "string"
        }
      },
      "required": [
        "population_group"
      ],
      "title": "PopulationProfile",
      "type": "object"
    },
    "ProductAmountUnit": {
      "enum": [
        "g",
        "mL"
      ],
      "title": "ProductAmountUnit",
      "type": "string"
    },
    "ProductUseEvidenceRecord": {
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "const": "productUseEvidenceRecord.v1",
          "default": "productUseEvidenceRecord.v1",
          "title": "Schema Version",
          "type": "string"
        },
        "chemical_id": {
          "description": "Stable chemical identifier shared with the request.",
          "title": "Chemical Id",
          "type": "string"
        },
        "preferred_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Preferred chemical name when the evidence source also carries identity data.",
          "title": "Preferred Name"
        },
        "casrn": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
