          "items": {
            "type": "string"
          },
          "title": "Physical Forms",
          "type": "array"
        },
        "application_methods": {
          "description": "Application methods supported by the evidence source.",
          "items": {
            "type": "string"
          },
          "title": "Application Methods",
          "type": "array"
        },
        "retention_types": {
          "description": "Retention or contact semantics supported by the evidence source.",
          "items": {
            "type": "string"
          },
          "title": "Retention Types",
          "type": "array"
        },
        "region_scopes": {
          "description": "Regions where the product-use evidence is considered applicable.",
          "items": {
            "type": "string"
          },
          "title": "Region Scopes",
          "type": "array"
        },
        "jurisdictions": {
          "description": "Jurisdictions or regulatory programs that back the evidence source.",
          "items": {
            "type": "string"
          },
          "title": "Jurisdictions",
          "type": "array"
        },
        "physchem_summary": {
          "additionalProperties": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              },
              {
                "type": "integer"
              },
              {
                "type": "boolean"
              },
              {
                "type": "null"
